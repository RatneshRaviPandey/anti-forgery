{
  "dashboard": {
    "id": null,
    "title": "Infometa Technologies Dashboard",
    "tags": ["infometa", "anti-counterfeit"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Health Status",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "up{job=\"infometa-app\"}",
            "legendFormat": "App Status"
          }
        ]
      },
      {
        "id": 2,
        "title": "API Response Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "http_request_duration_seconds{job=\"infometa-app\"}",
            "legendFormat": "{{method}} {{path}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Scan Verification Rate",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "rate(scans_total{result=\"authentic\"}[5m]) / rate(scans_total[5m]) * 100",
            "legendFormat": "Authentic %"
          }
        ]
      },
      {
        "id": 4,
        "title": "Active Alerts",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "alerts_open_total{job=\"infometa-app\"}",
            "legendFormat": "Open Alerts"
          }
        ]
      },
      {
        "id": 5,
        "title": "Scans per Minute",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "rate(scans_total[1m])",
            "legendFormat": "{{result}}"
          }
        ]
      }
    ],
    "time": { "from": "now-24h", "to": "now" },
    "refresh": "30s"
  }
}
